exports[`Palette DOM snapshots > renders the empty state when nothing matches 1`] = `
<DocumentFragment>
  <div
    class="palette-root"
  >
    <input
      aria-label="Search services"
      class="palette-search"
      placeholder="Search services…"
      type="text"
      value="zzzz-no-such-service"
    />
    <div
      aria-label="Filter by cloud provider"
      class="palette-providers"
      role="group"
    >
      <button
        aria-pressed="true"
        class="palette-provider is-active"
        type="button"
      >
        All
      </button>
      <button
        aria-pressed="false"
        class="palette-provider"
        type="button"
      >
        AWS
      </button>
      <button
        aria-pressed="false"
        class="palette-provider"
        type="button"
      >
        GCP
      </button>
      <button
        aria-pressed="false"
        class="palette-provider"
        type="button"
      >
        Azure
      </button>
    </div>
    <div
      class="help"
    >
      No services match “zzzz-no-such-service”.
    </div>
  </div>
</DocumentFragment>
`;

