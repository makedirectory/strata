{
  "name": "strata",
  "version": "0.2.1",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@10.9.3",
  "overrides": {
    "zod": "$zod",
    "postcss": "^8.5.10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:update": "vitest run -u",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@aws-sdk/client-cloudcontrol": "^3.1058.0",
    "@azure/arm-resourcegraph": "^4.2.1",
    "@azure/identity": "^4.13.1",
    "@google-cloud/asset": "^6.3.3",
    "js-yaml": "^4.2.0",
    "next": "^15.5.19",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^8",
    "eslint-config-next": "^15.5.19",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.7",
    "zod": "4.1.13"
  }
}
